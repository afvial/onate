  <encodingDesc>
    <projectDesc>
      <p>Edición digital del Tractatus XXI (<hi rend="italic">De emptione et
      venditione</hi>) de Pedro de Oñate. El texto se transcribe con criterios
      diplomáticos preservando las grafías originales del impreso del siglo XVII
      (ſ, æ, œ, macrones) y codificando abreviaturas mediante
      <gi>choice</gi>/<gi>abbr</gi>/<gi>expan</gi>. Una versión normalizada se
      ofrece paralelamente mediante <gi>choice</gi>/<gi>orig</gi>/<gi>reg</gi>.
      La anotación morfológica (lema, categoría gramatical, morfología) se
      realiza con LatinCy (modelo la_core_web_lg).</p>
    </projectDesc>
    <editorialDecl>
      <normalization>
        <p>Las grafías originales del impreso se preservan en el elemento
        <gi>orig</gi>. La forma normalizada se ofrece en <gi>reg</gi>.
        Las abreviaturas se desarrollan en <gi>expan</gi> sin marcar
        las letras restituidas.</p>
      </normalization>
      <punctuation>
        <p>La puntuación original se conserva y se codifica mediante
        <gi>pc</gi>.</p>
      </punctuation>
      <hyphenation>
        <p>Las palabras partidas por salto de línea se codifican con
        <gi>lb</gi> con atributo <att>break</att> igual a <val>no</val>
        dentro del elemento <gi>w</gi>.</p>
      </hyphenation>
      <!-- Política específica para las citas de autoridad -->
      <interpretation>
        <p>Cada invocación de autoridad en las notas marginales se encierra
        en <gi>cit</gi> con <att>xml:id</att> único. El elemento
        <gi>bibl</gi> lleva <att>corresp</att> apuntando al registro
        correspondiente en <gi>listBibl</gi> dentro de <gi>sourceDesc</gi>,
        y <att>cert</att> indicando la seguridad de la identificación
        (<val>high</val>, <val>medium</val>, <val>low</val>,
        <val>unknown</val>). Las adiciones editoriales se marcan con
        <gi>supplied</gi> y <att>resp</att>. Los comentaristas citados
        mediante la fórmula <mentioned>ibi</mentioned> se agrupan en
        <gi>note</gi> con <att>type</att> igual a <val>ref</val> y
        <att>subtype</att> igual a <val>ibi</val>, anidado dentro del
        <gi>bibl</gi> de la obra primaria. Las remisiones internas del
        tipo <mentioned>iuncto N</mentioned> se codifican con
        <gi>note</gi> <att>subtype</att> <val>iuncto</val> y
        <gi>ref</gi> <att>type</att> <val>crossref</val>.</p>
        <p>Valores del atributo <att>unit</att> en <gi>biblScope</gi>:
          <list type="gloss">
            <label>book</label><item>libro</item>
            <label>part</label><item>parte (p. ej. II–II de la ST)</item>
            <label>chap</label><item>capítulo</item>
            <label>quaestio</label><item>cuestión</item>
            <label>articulus</label><item>artículo</item>
            <label>ad</label><item>respuesta a objeción (ad N.um)</item>
            <label>dist</label><item>distinción (Sententiae)</item>
            <label>disput</label><item>disputación</item>
            <label>punct</label><item>punctum</item>
            <label>tract</label><item>tractado</item>
            <label>dub</label><item>dubium</item>
            <label>tit</label><item>título</item>
            <label>n</label><item>número (numerus)</item>
            <label>lemma</label><item>lema en summa alfabética</item>
          </list>
        </p>
      </interpretation>
    </editorialDecl>
    <tagsDecl>
      <namespace name="http://www.tei-c.org/ns/1.0">
        <tagUsage gi="w">Cada token léxico con atributos lemma, pos y msd
        generados por LatinCy.</tagUsage>
        <tagUsage gi="pc">Signo de puntuación con atributo type
        (period, comma, ampersand).</tagUsage>
        <tagUsage gi="choice">Par diplomático/normalizado o abreviatura/expansión.</tagUsage>
        <tagUsage gi="note">Marginalia del impreso original, y notas de
        tipo <val>ref</val> para agrupar comentaristas citados
        <mentioned>ibi</mentioned>.</tagUsage>
        <tagUsage gi="cit">Cita de autoridad completa en nota marginal;
        contiene siempre un <gi>bibl</gi> y opcionalmente
        <gi>cit</gi> anidados para comentaristas.</tagUsage>
        <tagUsage gi="bibl">Referencia bibliográfica concreta; lleva
        <att>corresp</att> al registro en <gi>listBibl</gi> y
        <att>cert</att> para la seguridad de identificación.</tagUsage>
        <tagUsage gi="biblScope">División interna de la obra citada
        (libro, capítulo, quaestio, etc.); usar <att>unit</att>
        según los valores declarados en <gi>interpretation</gi>.</tagUsage>
        <tagUsage gi="supplied">Adición editorial ausente en el original;
        lleva siempre <att>resp</att>.</tagUsage>
      </namespace>
    </tagsDecl>
